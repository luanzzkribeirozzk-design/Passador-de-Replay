<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141414"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NETFLIX"
            android:textColor="#E50914"
            android:textSize="42sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LN - REPLAY"
            android:textColor="#555555"
            android:textSize="11sp"
            android:letterSpacing="0.3"
            android:layout_marginBottom="28dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1F1F1F"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SHIZUKU"
                        android:textColor="#E50914"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.2"/>
                    <TextView
                        android:id="@+id/tvShizukuStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verificando..."
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <Button
                    android:id="@+id/btnShizuku"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="AUTORIZAR"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:backgroundTint="#E50914"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1F1F1F"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="14dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FF Max para FF Normal"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copia seus replays do Free Fire Max para o Free Fire Normal"
                    android:textColor="#777777"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"/>
                <Button
                    android:id="@+id/btnTransfer"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="TRANSFERIR"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#E50914"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1F1F1F"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FF Normal para FF Max"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copia seus replays do Free Fire Normal para o Free Fire Max"
                    android:textColor="#777777"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"/>
                <Button
                    android:id="@+id/btnTransferReverse"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="TRANSFERIR"
                    android:textColor="#CCCCCC"
                    android:backgroundTint="#2A2A2A"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="#E50914"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aguardando Shizuku..."
            android:textColor="#FFA500"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0D0D0D"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="32dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOG"
                    android:textColor="#555555"
                    android:textSize="10sp"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma acao realizada ainda."
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
